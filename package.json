{
    "name": "cardano-mcp",
    "version": "0.1.0",
    "description": "Production-grade MCP server for Cardano blockchain development",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc && cp -r src/resources dist/resources",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "lint": "eslint src/ --ext .ts",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@emurgo/cardano-serialization-lib-nodejs": "^12.0.0",
        "@meshsdk/core": "^1.7.0",
        "@modelcontextprotocol/sdk": "^1.0.0",
        "zod": "^4.4.2"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitest/coverage-v8": "^1.6.0",
        "eslint": "^8.57.0",
        "tsx": "^4.0.0",
        "typescript": "^5.4.0",
        "vitest": "^1.6.0"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "yarn@1.22.22"
}
